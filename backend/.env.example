# Copy this file to backend/.env on the server and replace every placeholder.
# Do not commit backend/.env.
WHATSAPP_TOKEN=replace-with-system-user-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
WHATSAPP_APP_SECRET=replace-with-app-secret
WHATSAPP_VERIFY_TOKEN=replace-with-long-random-verify-token
OPENAI_API_KEY=replace-with-openai-api-key
SARVAM_API_KEY=replace-with-sarvam-api-key

# Docker Compose overrides this with its internal Postgres hostname.
DATABASE_URL=postgres://sellthat:sellthat@postgres:5432/sellthat
PORT=3000
PUBLIC_BASE_URL=https://sellthat.in

# A real community invite is required before seller verification can publish.
COMMUNITY_LINK=https://chat.whatsapp.com/replace-with-real-invite

# These verified defaults can normally be left unchanged.
WHATSAPP_API_VERSION=v23.0
OPENAI_MODEL=gpt-5.4-mini
SARVAM_STT_MODEL=saarika:v2.5
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_MAX_CHARS=1200
